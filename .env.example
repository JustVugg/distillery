# LLM provider. One of: ollama, openai.
DISTILLERY_PROVIDER=ollama

# Ollama endpoint (when provider=ollama).
DISTILLERY_OLLAMA_BASE_URL=http://127.0.0.1:11434

# OpenAI-compatible endpoint (when provider=openai). Works with OpenAI, Groq,
# Together, Fireworks, vLLM, LM Studio, etc.
DISTILLERY_OPENAI_BASE_URL=https://api.openai.com/v1
DISTILLERY_OPENAI_API_KEY=

# Default generator and judge models.
DISTILLERY_GENERATOR_MODEL=llama3.1:8b
DISTILLERY_JUDGE_MODEL=llama3.1:8b

# Embedding model for diversity filtering (sentence-transformers compatible).
DISTILLERY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Workspace root for cached chunks, embeddings, and outputs.
DISTILLERY_WORKSPACE=./distillery_workspace
